#Options
GenerateScanner = true
GenerateParser = true
Language = Java
ScannerName = Lexico
ParserName = Sintatico
SemanticName = Semantico
Package = compiler.gals
ScannerCaseSensitive = true
ScannerTable = Compact
Input = String
Parser = SLR
#RegularDefinitions

#Tokens
:[\n\t\r\s]

// COMMENTS
: [/][/][^\n\r]*
: "/*" ([^"*"] | "*"+[^/])* "*/"

// IDENTIFIERS AND KEYWORDS
variable: [a-zA-Z_][a-zA-Z0-9_]*

char = variable : "char"
string = variable : "string"
bool = variable : "bool"
short = variable : "short"
int = variable : "int"
long = variable : "long"
float = variable : "float"
double = variable : "double"
decimal = variable : "decimal"

if = variable : "if"
elif = variable : "elif"
else = variable : "else"
while = variable : "while"
for = variable : "for"
do = variable : "do"
return = variable : "return"

read = variable : "read"
write = variable : "write"

// LITERALS
number: [0-9]+
binary_number: 0b[01]+
hex_number: 0x[0-9a-fa-f]+
real_number: [0-9]+\.[0-9]+
char_literal: '[^']'
string_literal: \"[^\"]*\"
true: "true"
false: "false"
null: "null"

// OPERATORS
bit_shift_left: "<<"
bit_shift_right: ">>"
bit_and: "&"
bit_or: "|"
bit_xor: "^"
bit_not: "~"

and: "&&"
or: "||"
not: "!"

greater_than: ">"
less_than: "<"
greater_equal: ">="
less_equal: "<="
equality: "=="
inequality: "!="

equals: "="
addition: "+"
subtraction: "-"
multiplication: "*"
division: "/"
remainder: "%"

increment: "++"
decrement: "--"

addition_equals: "+="
subtraction_equals: "-="
multiplication_equals: "*="
division_equals: "/="
modulus_equals: "%="

// PARENTHESES, BRACKETS, BRACES
open_parentheses: "("
close_parentheses: ")"
open_bracket: "["
close_bracket: "]"
open_brace: "{"
close_brace: "}"
comma: ","
colon: ":"
dot: "."
semicolon: ";"

void = variable : "void"
#NonTerminals
<program>
<empty>
<literal>
<assignment_operator>
<prefix_unary>
<variable_type>
<logical_operator>
<bitwise_operator>
<equality_operator>
<relational_operator>
<shift_operator>
<additive_operator>
<multiplicative_operator>
<block>
<statement>
<statement_list>
<variable_access>
<variable_declaration>
<declarator_list>
<declarator>
<vector_declaration_opt>
<vector_initializer_opt>
<vector_initializer>
<vector_initializer_list>
<conditional_statement>
<loop_statement>
<while_loop>
<do_while_loop>
<for_loop>
<for_init>
<for_update>
<function_definition>
<parameter_list_opt>
<parameter_list>
<parameter>
<function_call>
<argument_list>
<argument>
<expression_list>
<expression>
<assignment>
<logical>
<bitwise>
<equality>
<relational>
<shift>
<additive>
<multiplicative>
<unary_expression>
<postfix_expression>
<primary>
<input_statement>
<input_list>
<output_statement>
<output_list>
<output_item>
<assign_target>
<scope_open>
<scope_close>
#Grammar
<empty> ::= î;


<literal> ::=
  number #0
  | binary_number #2
  | hex_number #3
  | real_number #4
  | char_literal #5
  | string_literal #6
  | true #7
  | false #8
  | null #9;


<assignment_operator> ::=
  equals 
  | addition_equals
  | subtraction_equals
  | multiplication_equals
  | division_equals
  | modulus_equals;


<prefix_unary> ::= 
  not
  | bit_not
  | addition
  | subtraction
  | increment
  | decrement;


<variable_type> ::= 
  bool #10
  | short #10
  | int #10
  | long #10
  | float #10
  | double #10
  | decimal #10
  | char #10
  | string #10;


<logical_operator> ::=
  and #20
  | or #20;


<bitwise_operator> ::=
  bit_or 
  | bit_xor
  | bit_and;


<equality_operator> ::= 
  equality #19
  | inequality #19;


<relational_operator> ::=
  greater_than #19
  | less_than #19
  | greater_equal #19
  | less_equal #19;


<shift_operator> ::= 
 bit_shift_left
  | bit_shift_right;


<additive_operator> ::=
  addition #17
  | subtraction #17;


<multiplicative_operator> ::=
  multiplication #18
  | division #18
  | remainder #18;


<block> ::= 
  <scope_open> <scope_close>
  | <scope_open> <statement_list> <scope_close>;

  <scope_open> ::= open_brace #15;
  <scope_close> ::= close_brace #16;


<program> ::= <statement_list>;


<statement> ::= 
  <variable_declaration> semicolon
  | <expression> semicolon
  | return <expression> semicolon
  | <conditional_statement>
  | <loop_statement>
  | <input_statement>
  | <output_statement>
  | <function_definition>;

    
<statement_list> ::= 
  <statement_list> <statement>
  | <statement>;
    

<variable_access> ::= 
  variable #12
  | variable open_bracket <expression> close_bracket;


<assign_target> ::=
    variable #14;


<variable_declaration> ::= <variable_type> <declarator_list>;


<declarator_list> ::= 
  <declarator> 
  | <declarator_list> comma <declarator>;

  
<declarator> ::=
  variable #11
  | variable #11 equals <expression> #22
  | variable #11 open_bracket <vector_declaration_opt> close_bracket <vector_initializer_opt>;

    
<vector_declaration_opt> ::= 
  <expression> 
  | <empty>;


<vector_initializer_opt> ::= 
  equals <vector_initializer> 
  | <empty>;


<vector_initializer> ::= 
  open_brace close_brace
  | open_brace <vector_initializer_list> close_brace;

    
<vector_initializer_list> ::= 
  <vector_initializer_list> comma <expression>
  | <expression>;

    
<conditional_statement> ::= 
  if open_parentheses <expression> close_parentheses <block>
  | if open_parentheses <expression> close_parentheses <block> else <block>;


<loop_statement> ::= 
  <while_loop>
  | <do_while_loop>
  | <for_loop>;


<while_loop> ::= while open_parentheses <expression> close_parentheses <block>;


<do_while_loop> ::= do <block> while open_parentheses <expression> close_parentheses semicolon;


<for_loop> ::= for open_parentheses <for_init> semicolon <expression> semicolon <for_update> close_parentheses <block>;


<for_init> ::= 
  <variable_declaration> 
  | <empty>;


<for_update> ::= 
  <expression_list>
  | <empty>;


<function_definition> ::= 
  void variable open_parentheses <parameter_list_opt> close_parentheses <block>
  | <variable_type> variable open_parentheses <parameter_list_opt> close_parentheses <block>;


<parameter_list_opt> ::= 
  <parameter_list> 
  | <empty>;


<parameter_list> ::= 
  <parameter> 
  | <parameter_list> comma <parameter>;

  
<parameter> ::= 
  <variable_type> variable #23
  | <variable_type> variable #23 open_bracket close_bracket;


<function_call> ::= 
  variable open_parentheses close_parentheses
  | variable open_parentheses <argument_list> close_parentheses;


<argument_list> ::= 
  <argument> 
  | <argument_list> comma <argument>;


<argument> ::= <expression>;


<expression_list> ::=
  <expression>
  | <expression_list> comma <expression>;


<expression> ::= <assignment>;


<assignment> ::=
  <assign_target> <assignment_operator> <assignment> #13
  | <assign_target> open_bracket <expression> close_bracket <assignment_operator> <assignment> #13
  | <logical>;


<logical> ::=
  <logical> <logical_operator> <bitwise> #21
  | <bitwise>;


<bitwise> ::=
  <bitwise> <bitwise_operator> <equality>
  | <equality>;


<equality> ::= 
  <equality> <equality_operator> <relational> #21
  | <relational>;


<relational> ::=
  <relational> <relational_operator> <shift> #21
  | <shift>;


<shift> ::= 
  <shift> <shift_operator> <additive>
  | <additive>;


<additive> ::=
  <additive> <additive_operator> <multiplicative> #21
  | <multiplicative>;


<multiplicative> ::=
  <multiplicative> <multiplicative_operator> <unary_expression> #21
  | <unary_expression>;


<unary_expression> ::= 
  <postfix_expression>
  | <prefix_unary> <unary_expression>;


<postfix_expression> ::=
  <primary>
  | <postfix_expression> increment
  | <postfix_expression> decrement;


<primary> ::= 
  <literal>
  | <variable_access>
  | <function_call>
  | open_parentheses <expression> close_parentheses;


<input_statement> ::= read open_parentheses <input_list> close_parentheses semicolon;


<input_list> ::= 
    <variable_access>
    | <variable_access> comma <input_list>
    | <empty>;


<output_statement> ::= write open_parentheses <output_list> close_parentheses semicolon;


<output_list> ::= 
    <output_item> 
    | <output_item> comma <output_list>
    | <empty>;


<output_item> ::= <expression>;