#Options
GenerateScanner = true
GenerateParser = true
Language = Java
ScannerName = Lexico
ParserName = Sintatico
SemanticName = Semantico
Package = br.compiler.gals
ScannerCaseSensitive = true
ScannerTable = Compact
Input = String
Parser = SLR
#RegularDefinitions

#Tokens
:[\n\t\r\s]

// COMMENTS
line_comment: [/][/][^\n\r]*
block_comment: "/*" ([^"*"] | "*"+[^/])* "*/"

// IDENTIFIERS AND KEYWORDS
variable: [a-zA-Z_][a-zA-Z0-9_]*

char = variable : "char"
string = variable : "string"
bool = variable : "bool"
short = variable : "short"
int = variable : "int"
long = variable : "long"
float = variable : "float"
double = variable : "double"
decimal = variable : "decimal"

if = variable : "if"
elif = variable : "elif"
else = variable : "else"
while = variable : "while"
for = variable : "for"
do = variable : "do"
return = variable : "return"

read = variable : "read"
write = variable : "write"

// LITERALS
number: [0-9]+
binary_number: 0b[01]+
hex_number: 0x[0-9a-fa-f]+
real_number: [0-9]+\.[0-9]+
char_literal: '[^']'
string_literal: \"[^\"]*\"
true: "true"
false: "false"
null: "null"

// OPERATORS
bit_shift_left: "<<"
bit_shift_right: ">>"
bit_and: "&"
bit_or: "|"
bit_xor: "^"
bit_not: "~"

and: "&&"
or: "||"
not: "!"

greater_than: ">"
less_than: "<"
greater_equal: ">="
less_equal: "<="
equality: "=="
inequality: "!="

equals: "="
addition: "+"
subtraction: "-"
multiplication: "*"
division: "/"
remainder: "%"

increment: "++"
decrement: "--"

addition_equals: "+="
subtraction_equals: "-="
multiplication_equals: "*="
division_equals: "/="
modulus_equals: "%="

// PARENTHESES, BRACKETS, BRACES
open_parentheses: "("
close_parentheses: ")"
open_bracket: "["
close_bracket: "]"
open_brace: "{"
close_brace: "}"
comma: ","
colon: ":"
dot: "."
semicolon: ";"

void = variable : "void"
#NonTerminals
<program>
<empty>
<literal>
<assignment_operator>
<prefix_unary>
<comment>
<variable_type>
<statement>
<statement_list>
<variable_access>
<variable_declaration>
<declarator_list>
<declarator>
<vector_declaration_opt>
<vector_initializer_opt>
<vector_initializer>
<vector_initializer_list>
<variable_assignment>
<conditional_statement>
<loop_statement>
<while_loop>
<do_while_loop>
<for_loop>
<for_init>
<for_update>
<function_definition>
<parameter_list_opt>
<parameter_list>
<parameter>
<function_call>
<argument_list>
<argument>
<expression>
<logical>
<equality>
<relational>
<shift>
<additive>
<multiplicative>
<unary_expression>
<primary>
<block>
<input_statement>
<input_list>
<output_statement>
<output_list>
<output_item>
#Grammar
<empty> ::= î;

<literal> ::=
      number
    | binary_number
    | hex_number
    | real_number
    | char_literal
    | string_literal
    | true
    | false
    | null;

<assignment_operator> ::=
  equals 
   | addition_equals
   | subtraction_equals
   | multiplication_equals
   | division_equals
   | modulus_equals;

<prefix_unary> ::= 
  not
  | bit_not
  | addition
  | subtraction
  | increment
  | decrement;

<comment> ::= 
     line_comment
    | block_comment;
    
<variable_type> ::= bool | short | int | long | float | double | decimal | char | string;

<program> ::= <statement_list>;

<statement> ::= 
      <variable_declaration> semicolon
    | <variable_assignment> semicolon
    | <expression> semicolon
    | return <expression> semicolon
    | <conditional_statement>
    | <loop_statement>
    | <input_statement>
    | <output_statement>
    | <function_definition>
    | <comment>;
    
<statement_list> ::= 
    <statement_list> <statement>
  | <statement>;
    


<variable_access> ::= 
    variable
  | variable open_bracket <expression> close_bracket;

<variable_declaration> ::= <variable_type> <declarator_list>;
<declarator_list> ::= <declarator> | <declarator_list> comma <declarator>;
<declarator> ::=
      variable
    | variable equals <expression>
    | variable open_bracket <vector_declaration_opt> close_bracket <vector_initializer_opt>;
<vector_declaration_opt> ::= <expression> | <empty>;
<vector_initializer_opt> ::= equals <vector_initializer> | <empty>;
<vector_initializer> ::= 
      open_brace close_brace
    | open_brace <vector_initializer_list> close_brace;
<vector_initializer_list> ::= 
      <vector_initializer_list> comma <expression>
    | <expression>;

<variable_assignment> ::= <variable_access> <assignment_operator> <expression>;

<conditional_statement> ::= 
      if open_parentheses <expression> close_parentheses <block>
    | if open_parentheses <expression> close_parentheses <block> else <block>;

<loop_statement> ::= 
  <while_loop>
 | <do_while_loop>
 | <for_loop>;

<while_loop> ::= while open_parentheses <expression> close_parentheses <block>;

<do_while_loop> ::= do <block> while open_parentheses <expression> close_parentheses semicolon;

<for_loop> ::= for open_parentheses <for_init> semicolon <expression> semicolon <for_update> close_parentheses <block>;

<for_init> ::= 
  <variable_declaration> 
  | <empty>;

<for_update> ::= 
  <variable_assignment>
  | <variable_assignment> comma <for_update>
  | <empty>;

<function_definition> ::= 
   void variable open_parentheses <parameter_list_opt> close_parentheses <block>
  | <variable_type> variable open_parentheses <parameter_list_opt> close_parentheses <block>;

<parameter_list_opt> ::= <parameter_list> | <empty>;
<parameter_list> ::= <parameter> | <parameter_list> comma <parameter>;
<parameter> ::= <variable_type> variable | <variable_type> variable open_bracket close_bracket;

<function_call> ::= 
  variable open_parentheses close_parentheses
  | variable open_parentheses <argument_list> close_parentheses;

<argument_list> ::= <argument> | <argument_list> comma <argument>;
<argument> ::= <expression>;

<expression> ::= <logical>;

<logical> ::=
      <logical> and <equality>
    | <logical> or <equality>
    | <equality>;

<equality> ::= 
  <equality> equality <relational>
  | <equality> inequality <relational>
  | <relational>;

<relational> ::=
      <relational> greater_than <shift>
    | <relational> less_than <shift>
    | <relational> greater_equal <shift>
    | <relational> less_equal <shift>
    | <shift>;

<shift> ::= 
  <shift> bit_shift_left <additive>
  | <shift> bit_shift_right <additive>
  | <additive>;

<additive> ::=
      <additive> addition <multiplicative>
    | <additive> subtraction <multiplicative>
    | <multiplicative>;

<multiplicative> ::=
      <multiplicative> multiplication <unary_expression>
    | <multiplicative> division <unary_expression>
    | <multiplicative> remainder <unary_expression>
    | <unary_expression>;

<unary_expression> ::= 
  <prefix_unary> <unary_expression>
  | <primary>;

<primary> ::= 
    <literal>
  | <variable_access>
  | <function_call>
  | open_parentheses <expression> close_parentheses;

<block> ::= open_brace close_brace | open_brace <statement_list> close_brace;

<input_statement> ::= read open_parentheses <input_list> close_parentheses semicolon;

<input_list> ::= 
    <variable_access>
    | <variable_access> comma <input_list>
    | <empty>;

<output_statement> ::= write open_parentheses <output_list> close_parentheses semicolon;

<output_list> ::= 
    <output_item> 
    | <output_item> comma <output_list>
    | <empty>;

<output_item> ::= <expression>;